# SteadyPrice Enterprise Environment Configuration

# Application Settings
APP_NAME=SteadyPrice Enterprise
VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production

# Database Configuration
DATABASE_URL=postgresql://admin:secure_password_123@postgres:5432/steadyprice
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://redis:6379
CACHE_TTL=3600

# Security
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
ALLOWED_HOSTS=["http://localhost:3000", "http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=100

# Machine Learning
MODEL_CACHE_DIR=./models
MAX_PREDICTION_BATCH_SIZE=100
MODEL_CONFIDENCE_THRESHOLD=0.7

# HuggingFace (Optional - for Amazon data access)
HF_TOKEN=your_huggingface_token_here
HF_MODEL_NAME=microsoft/DialoGPT-medium

# Monitoring
PROMETHEUS_PORT=8001
LOG_LEVEL=INFO

# External APIs (Optional)
AMAZON_API_KEY=your_amazon_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
